# ─── Unsplash API (for background images) ───
UNSPLASH_ACCESS_KEY=
UNSPLASH_Secret_KEY=

# ─── Cloudflare R2 (S3 Compatible) Storage ───
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── GROQ AI (for auto-sync via Whisper) ───
GROQ_API_KEY=

# ─── JWT Authentication (required) ───
JWT_SECRET=

# ─── Redis ───
# Set automatically by Docker Compose, override if needed
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=changeme
# Or use a full Redis URL (e.g. for Upstash):
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ─── CORS (comma-separated allowed origins) ───
# ALLOWED_ORIGINS=http://localhost:3001,https://yourdomain.com

# ─── Server ───
# PORT=3001

# ─── Turso Database (for cloud deployment; falls back to local SQLite if not set) ───
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your_auth_token

# ─── Email (Resend - for email verification & password reset) ───
# Sign up for free at https://resend.com (100 emails/day on free tier)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=QVM <onboarding@resend.dev>
APP_URL=https://your-app-url.com